{% extends 'base.html.twig' %}

{% block title %}Carnets de voyage — Horizons{% endblock %}

{% block body %}
<div class="page-container">

    <div class="page-header">
        <div>
            <p class="page-kicker">Carnets de voyage</p>
            <h1 class="page-title">Tous les horizons</h1>
        </div>
        <span class="page-count">{{ journeys.getTotalItemCount() }} carnets</span>
    </div>

    {# Formulaire de recherche et filtres #}
    <form method="get" action="{{ path('app_journey_index') }}" class="search-bar">
        <input type="text"
               name="search"
               class="search-input"
               placeholder="Rechercher un carnet..."
               value="{{ search ?? '' }}">

        <select name="category" class="search-select">
            <option value="">Toutes les catégories</option>
            {% for category in categories %}
                <option value="{{ category.id }}"
                    {{ currentCategory is defined and currentCategory == category.id ? 'selected' : '' }}>
                    {{ category.name }}
                </option>
            {% endfor %}
        </select>

        <button type="submit" class="btn-accent">Rechercher</button>
    </form>

    {# Grille de carnets #}
    <div class="journey-grid">
        {% for journey in journeys %}
        <a href="{{ path('app_journey_show', {slug: journey.slug}) }}" class="journey-card">

            <div class="journey-card-image">
                {% if journey.coverImage %}
                    <img src="{{ asset('uploads/journeys/' ~ journey.coverImage) }}" alt="{{ journey.title }}">
                {% endif %}
                {% if journey.category %}
                    <span class="journey-category-tag journey-category-{{ cycle(['accent', 'secondary'], loop.index0) }}">
                        {{ journey.category.name }}
                    </span>
                {% endif %}
            </div>

            <div class="journey-card-body">
                <h3 class="journey-card-title">{{ journey.title }}</h3>
                <p class="journey-card-text">{{ journey.description|slice(0, 110) }}...</p>
            </div>

            <div class="journey-card-footer">
                <span>{{ journey.duration }} jours · {{ journey.budget }} €</span>
                <i class="ti ti-arrow-right"></i>
            </div>

        </a>
        {% else %}
            <p class="text-muted">Aucun carnet de voyage pour le moment.</p>
        {% endfor %}
    </div>

    <div class="pagination-wrapper">
        {{ knp_pagination_render(journeys) }}
    </div>

</div>
{% endblock %}