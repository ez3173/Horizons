{% extends 'base.html.twig' %}

{% block title %}Carnets de voyage — Horizons{% endblock %}

{% block body %}
<div class="container mt-4">

    {# Titre + nombre de résultats #}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Carnets de voyage</h1>
        <span class="text-muted">{{ journeys.getTotalItemCount() }} carnets</span>
    </div>

    {# Grille de carnets #}
    <div class="row">
        {% for journey in journeys %}
        <div class="col-md-4 mb-4">
            <div class="card h-100">

                {# Image de couverture #}
                {% if journey.coverImage %}
                    <img src="{{ asset('uploads/journeys/' ~ journey.coverImage) }}"
                         class="card-img-top"
                         alt="{{ journey.title }}"
                         style="height: 200px; object-fit: cover;">
                {% else %}
                    <div class="bg-secondary d-flex align-items-center justify-content-center"
                         style="height: 200px;">
                        <span class="text-white">Pas d'image</span>
                    </div>
                {% endif %}

                <div class="card-body">
                    {# Catégorie #}
                    {% if journey.category %}
                        <span class="badge bg-primary mb-2">{{ journey.category.name }}</span>
                    {% endif %}

                    {# Titre #}
                    <h5 class="card-title">{{ journey.title }}</h5>

                    {# Description tronquée #}
                    <p class="card-text text-muted">
                        {{ journey.description|slice(0, 120) }}...
                    </p>
                </div>

                <div class="card-footer d-flex justify-content-between align-items-center">
                    <small class="text-muted">
                        {{ journey.duration }} jours —
                        {{ journey.budget }} €
                    </small>
                    {# Lien vers le détail #}
                    <a href="{{ path('app_journey_show', {slug: journey.slug}) }}"
                       class="btn btn-sm btn-outline-primary">
                        Voir
                    </a>
                </div>

            </div>
        </div>
        {% else %}
            <p class="text-muted">Aucun carnet de voyage pour le moment.</p>
        {% endfor %}
    </div>

    {# Pagination #}
    <div class="d-flex justify-content-center mt-4">
        {{ knp_pagination_render(journeys) }}
    </div>

</div>
{% endblock %}
