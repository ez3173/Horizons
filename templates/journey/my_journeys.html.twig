{% extends 'base.html.twig' %}

{% block title %}Mes carnets — Horizons{% endblock %}

{% block body %}
<div class="page-container">

    <div class="page-header">
        <div>
            <p class="page-kicker">Mon espace</p>
            <h1 class="page-title">Mes carnets de voyage</h1>
        </div>
        <a href="{{ path('app_journey_new') }}" class="btn-accent">+ Nouveau carnet</a>
    </div>

    {% if journeys|length == 0 %}
    <div class="empty-state">
        <p class="empty-state-title">Vous n'avez pas encore de carnet</p>
        <p class="empty-state-text">Commencez par raconter votre premier voyage !</p>
        <a href="{{ path('app_journey_new') }}" class="btn-accent">Créer mon premier carnet</a>
    </div>
    {% else %}
    <div class="list-grid">
        {% for journey in journeys %}
        <div class="list-card {{ not journey.published ? 'list-card-draft' : '' }}">

            <div class="list-card-image">
                {% if journey.coverImage %}
                    <img src="{{ asset('uploads/journeys/' ~ journey.coverImage) }}" alt="{{ journey.title }}">
                {% else %}
                    <div class="list-card-image-placeholder">🗺️</div>
                {% endif %}
                {# Badge publié / brouillon #}
                <span class="list-card-badge {{ journey.published ? 'list-card-badge-secondary' : 'journey-status-draft' }}">
                    {{ journey.published ? 'Publié' : 'Brouillon' }}
                </span>
            </div>

            <div class="list-card-body">
                <h3 class="list-card-title">{{ journey.title }}</h3>
                <p class="list-card-text">{{ journey.description|slice(0, 100) }}...</p>
                <div class="list-card-footer">
                    <span>{{ journey.duration }} jours · {{ journey.budget }} €</span>
                    <div class="list-card-actions">
                        <a href="{{ path('app_journey_show', {slug: journey.slug}) }}" class="list-card-link list-card-link-light">
                            Voir
                        </a>
                        <a href="{{ path('app_journey_edit', {slug: journey.slug}) }}" class="list-card-link list-card-link-accent">
                            Modifier
                        </a>
                    </div>
                </div>
            </div>

        </div>
        {% endfor %}
    </div>
    {% endif %}

</div>
{% endblock %}
