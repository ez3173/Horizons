{% extends 'base.html.twig' %}

{% block title %}Mes carnets — Horizons{% endblock %}

{% block body %}
<div class="container mt-4">
    <h1>Mes carnets de voyage</h1>

    <a href="{{ path('app_journey_new') }}" class="btn btn-success mb-4">
        + Créer un nouveau carnet
    </a>

    <div class="row">
        {% for journey in journeys %}
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-body">
                    {% if journey.published %}
                        <span class="badge bg-success mb-2">Publié</span>
                    {% else %}
                        <span class="badge bg-secondary mb-2">Brouillon</span>
                    {% endif %}

                    <h5 class="card-title">{{ journey.title }}</h5>
                    <p class="card-text text-muted">
                        {{ journey.description|slice(0, 100) }}...
                    </p>
                </div>
                <div class="card-footer d-flex justify-content-between align-items-center">
                    <a href="{{ path('app_journey_show', {slug: journey.slug}) }}"
                       class="btn btn-sm btn-outline-primary">Voir</a>
                    <a href="{{ path('app_journey_edit', {slug: journey.slug}) }}"
                       class="btn btn-sm btn-outline-warning">Modifier</a>

                    <form method="post"
                          action="{{ path('app_journey_delete', {slug: journey.slug}) }}"
                          onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce carnet ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete'  ~ journey.id) }}">
                        <button class="btn btn-sm btn-outline-danger">Supprimer</button>
                    </form>
                </div>
            </div>
        </div>
        {% else %}
            <p class="text-muted">Vous n'avez pas encore créé de carnet.</p>
        {% endfor %}
    </div>
</div>
{% endblock %}