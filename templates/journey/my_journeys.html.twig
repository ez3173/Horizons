{% extends 'base.html.twig' %}

{% block title %}Mes carnets — Horizons{% endblock %}

{% block body %}
<div class="page-container">

    <div class="page-header">
        <div>
            <p class="page-kicker">Mon espace</p>
            <h1 class="page-title">Mes carnets de voyage</h1>
        </div>
        <a href="{{ path('app_journey_new') }}" class="btn-accent">+ Nouveau carnet</a>
    </div>

    <div class="journey-grid">
        {% for journey in journeys %}
        <div class="journey-card">

            <div class="journey-card-image">
                {% if journey.coverImage %}
                    <img src="{{ asset('uploads/journeys/' ~ journey.coverImage) }}" alt="{{ journey.title }}">
                {% endif %}
                <span class="journey-category-tag {{ journey.published ? 'journey-category-secondary' : 'journey-status-draft' }}">
                    {{ journey.published ? 'Publié' : 'Brouillon' }}
                </span>
            </div>

            <div class="journey-card-body">
                <h3 class="journey-card-title">{{ journey.title }}</h3>
                <p class="journey-card-text">{{ journey.description|slice(0, 100) }}...</p>
            </div>

            <div class="journey-card-footer">
                <span>{{ journey.duration }} jours · {{ journey.budget }} €</span>
                <div style="display:flex;gap:10px;">
                    <a href="{{ path('app_journey_show', {slug: journey.slug}) }}" style="font-size:12px;color:var(--color-text-light);text-decoration:none;">Voir</a>
                    <a href="{{ path('app_journey_edit', {slug: journey.slug}) }}" style="font-size:12px;color:var(--color-accent);text-decoration:none;">Modifier</a>
                </div>
            </div>

        </div>
        {% else %}
            <p style="color:var(--color-text-light);font-size:13px;">Vous n'avez pas encore créé de carnet.</p>
        {% endfor %}
    </div>

</div>
{% endblock %}