{% extends 'base.html.twig' %}

{% block title %}Créer un carnet — Horizons{% endblock %}

{% block body %}
<div class="page-container page-container-sm">

    <p class="page-kicker">Nouveau carnet</p>
    <h1 class="page-title">Raconter un voyage</h1>
    <p class="page-subtitle">
        Renseignez les infos générales, puis ajoutez vos étapes une par une.
    </p>

    {% for message in app.flashes('error') %}
        <div class="flash flash-error">{{ message }}</div>
    {% endfor %}

    {{ form_start(form, {'attr': {'class': 'horizons-form'}}) }}

    {# Informations générales du carnet #}
    <div class="form-card">
        <h2 class="form-card-title">Le voyage en bref</h2>

        {{ form_row(form.title) }}
        {{ form_row(form.description) }}

        <div class="form-row-2col">
            {{ form_row(form.budget) }}
            {{ form_row(form.duration) }}
        </div>

        {{ form_row(form.category) }}

        <div class="mb-3">
            <label class="file-upload-label" for="{{ form.coverImageFile.vars.id }}">
                ⛰️ Cliquez pour choisir une image de couverture
                <span class="file-upload-hint">JPEG, PNG, WEBP — 10 Mo max</span>
                <span id="file-name" class="file-upload-name"></span>
            </label>
            {{ form_widget(form.coverImageFile) }}
            {{ form_errors(form.coverImageFile) }}
        </div>
    </div>

    {# Étapes dynamiques via CollectionType #}
    <div class="steps-section">
        <div class="steps-section-header">
            <p class="page-kicker">Étapes du voyage</p>
            <span id="step-count" class="step-count">0 étape(s)</span>
        </div>
        <p class="steps-section-hint">
            Chaque étape représente une partie de votre voyage.
        </p>

        {# data-prototype contient le HTML d'une étape vide  #}
        <div id="steps-container" data-prototype="{{ form_widget(form.steps.vars.prototype)|e('html_attr') }}">
            {% for step in form.steps %}
            <div class="step-form-item">
                <div class="step-form-header">
                    <div class="step-form-header-left">
                        <span class="step-circle">{{ loop.index }}</span>
                        <span class="step-label">Étape {{ loop.index }}</span>
                    </div>
                    <button type="button" class="btn-remove-step">✕ Supprimer</button>
                </div>
                <div class="form-row-2col">
                    {{ form_row(step.duration) }}
                    {{ form_row(step.title) }}
                </div>
                {{ form_row(step.content) }}
            </div>
            {% endfor %}
        </div>

        <button type="button" id="add-step" class="btn-add-step">
            + Ajouter une étape
        </button>
    </div>

    {# Boutons publier / brouillon — un champ hidden transmet le choix #}
    <div class="form-actions">
        <input type="hidden" name="publish_action" id="publish_action" value="publish">
        <button type="submit" class="btn-accent" onclick="document.getElementById('publish_action').value='publish'">
            Publier le carnet
        </button>
        <button type="submit" class="btn-outline" onclick="document.getElementById('publish_action').value='draft'">
            Enregistrer en brouillon
        </button>
        <span class="form-actions-hint">Tout est modifiable plus tard</span>
    </div>
    {{ form_widget(form._token) }}
    {{ form_end(form, {'render_rest': false}) }}
</div>

{% block javascripts %}
{{ parent() }}
<script>
(function() {
    document.querySelector('input[type="file"]').addEventListener('change', function() {
        document.getElementById('file-name').textContent = this.files[0] ? this.files[0].name : '';
    });

    const stepsContainer = document.getElementById('steps-container');
    let index = stepsContainer.querySelectorAll('.step-form-item').length;

    function updateStepCount() {
        const count = stepsContainer.querySelectorAll('.step-form-item').length;
        document.getElementById('step-count').textContent = count + ' étape(s)';
        stepsContainer.querySelectorAll('.step-form-item').forEach((item, i) => {
            const circle = item.querySelector('.step-circle');
            const label  = item.querySelector('.step-label');
            if (circle) circle.textContent = i + 1;
            if (label)  label.textContent  = 'Étape ' + (i + 1);
        });
    }

    document.getElementById('add-step').onclick = function() {
        const newStep = stepsContainer.dataset.prototype.replace(/__name__/g, index);
        const div = document.createElement('div');
        div.classList.add('step-form-item');
        div.innerHTML = `
            <div class="step-form-header">
                <div class="step-form-header-left">
                    <span class="step-circle">${index + 1}</span>
                    <span class="step-label">Étape ${index + 1}</span>
                </div>
                <button type="button" class="btn-remove-step">✕ Supprimer</button>
            </div>
            ${newStep}
        `;
        stepsContainer.appendChild(div);
        index++;
        updateStepCount();
        bindRemoveButtons();
    };

    function bindRemoveButtons() {
        document.querySelectorAll('.btn-remove-step').forEach(btn => {
            btn.onclick = function() {
                this.closest('.step-form-item').remove();
                updateStepCount();
            };
        });
    }

    bindRemoveButtons();
    updateStepCount();
})();
</script>
{% endblock %}

{% endblock %}
