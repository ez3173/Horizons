{% extends 'base.html.twig' %}

{% block title %}{{ journey.title }} — Horizons{% endblock %}

{% block body %}
<div class="page-container">

    <a href="{{ path('app_journey_index') }}" class="back-link">
        <i class="ti ti-arrow-left"></i> Retour aux carnets
    </a>

    <div class="journey-detail-header">
        <div class="journey-detail-main">
            {% if journey.category %}
                <span class="journey-category-tag journey-category-secondary">{{ journey.category.name }}</span>
            {% endif %}
            <h1 class="journey-detail-title">{{ journey.title }}</h1>
            <p class="journey-detail-meta">
                Par <strong>{{ journey.author.username }}</strong> —
                {{ journey.createdAt|date('d/m/Y') }}
            </p>
            <p class="journey-detail-description">{{ journey.description }}</p>

            <div class="journey-detail-stats">
                <span><i class="ti ti-calendar"></i> {{ journey.duration }} jours</span>
                <span><i class="ti ti-coin"></i> {{ journey.budget }} €</span>
                <span><i class="ti ti-message-circle"></i> {{ journey.comments|length }} commentaires</span>
            </div>

            {% if app.user and (app.user == journey.author or is_granted('ROLE_ADMIN')) %}
                <a href="{{ path('app_journey_edit', {slug: journey.slug}) }}" class="btn-outline mt-3">
                    Modifier ce carnet
                </a>
            {% endif %}
        </div>

        <div class="journey-detail-image">
            {% if journey.coverImage %}
                <img src="{{ asset('uploads/journeys/' ~ journey.coverImage) }}" alt="{{ journey.title }}">
            {% endif %}
        </div>
    </div>

    {% if journey.steps|length > 0 %}
    <div class="section-block">
        <p class="page-kicker">Étapes du voyage</p>
        <div class="steps-list">
            {% for step in journey.steps %}
            <div class="step-item">
                <div class="step-number">{{ loop.index }}</div>
                <div>
                    <h3 class="step-title">{{ step.title }}</h3>
                    <p class="step-text">{{ step.content }}</p>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
    {% endif %}

    <div class="section-block">
        <p class="page-kicker">Commentaires ({{ journey.comments|length }})</p>

        <div class="comments-list">
            {% for comment in journey.comments %}
            <div class="comment-item">
                <p class="comment-text">{{ comment.content }}</p>
                <p class="comment-meta">{{ comment.author.username }} — {{ comment.createdAt|date('d/m/Y') }}</p>
            </div>
            {% else %}
                <p class="text-muted">Aucun commentaire pour le moment.</p>
            {% endfor %}
        </div>

        {% if app.user %}
            <form method="post" action="#" class="comment-form">
                <textarea class="comment-textarea" name="content" rows="3" placeholder="Votre commentaire..."></textarea>
                <button type="submit" class="btn-accent mt-2">Envoyer</button>
            </form>
        {% else %}
            <p class="mt-3">
                <a href="{{ path('app_login') }}" class="link-terracotta">Connectez-vous</a> pour laisser un commentaire.
            </p>
        {% endif %}
    </div>

</div>
{% endblock %}