{% extends 'base.html.twig' %}

{% block title %}{{ journey.title }} — Horizons{% endblock %}

{% block body %}
<div class="container mt-4">

    {# Bouton retour #}
    <a href="{{ path('app_journey_index') }}" class="btn btn-outline-secondary mb-3">
        ← Retour aux carnets
    </a>

    {# En-tête du carnet #}
    <div class="row mb-4">
        <div class="col-md-8">
            {% if journey.category %}
                <span class="badge bg-primary mb-2">{{ journey.category.name }}</span>
            {% endif %}
            <h1>{{ journey.title }}</h1>
            <p class="text-muted">
                Par <strong>{{ journey.author.username }}</strong> —
                {{ journey.createdAt|date('d/m/Y') }}
            </p>
            <div class="d-flex gap-3 mb-3">
                <span>🗓️ {{ journey.duration }} jours</span>
                <span>💶 {{ journey.budget }} €</span>
                <span>💬 {{ journey.comments|length }} commentaires</span>
            </div>
        </div>

        {# Image de couverture #}
        {% if journey.coverImage %}
        <div class="col-md-4">
            <img src="{{ asset('uploads/journeys/' ~ journey.coverImage) }}"
                 class="img-fluid rounded"
                 alt="{{ journey.title }}">
        </div>
        {% endif %}
    </div>

    {# Description #}
    <div class="mb-5">
        <h2>Description</h2>
        <p>{{ journey.description }}</p>
    </div>

    {# Étapes #}
    {% if journey.steps|length > 0 %}
    <div class="mb-5">
        <h2>Étapes du voyage</h2>
        {% for step in journey.steps %}
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">{{ step.title }}</h5>
                <p class="card-text">{{ step.content }}</p>
            </div>
        </div>
        {% endfor %}
    </div>
    {% endif %}

    {# Commentaires #}
    <div class="mb-5">
        <h2>Commentaires ({{ journey.comments|length }})</h2>

        {% for comment in journey.comments %}
        <div class="card mb-2">
            <div class="card-body">
                <p class="mb-1">{{ comment.content }}</p>
                <small class="text-muted">
                    {{ comment.author.username }} —
                    {{ comment.createdAt|date('d/m/Y') }}
                </small>
            </div>
        </div>
        {% else %}
            <p class="text-muted">Aucun commentaire pour le moment.</p>
        {% endfor %}

        {# Formulaire de commentaire — uniquement si connecté #}
        {% if app.user %}
            <div class="mt-3">
                <h5>Laisser un commentaire</h5>
                <form method="post" action="#">
                    <div class="mb-3">
                        <textarea class="form-control" name="content" rows="3"
                                  placeholder="Votre commentaire..."></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary">Envoyer</button>
                </form>
            </div>
        {% else %}
            <p class="mt-3">
                <a href="{{ path('app_login') }}">Connectez-vous</a>
                pour laisser un commentaire.
            </p>
        {% endif %}
    </div>

</div>
{% endblock %}