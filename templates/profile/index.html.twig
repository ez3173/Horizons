{% extends 'base.html.twig' %}

{% block title %}Mon profil — Horizons{% endblock %}

{% block body %}
<div class="page-container page-container-md">

    <div class="page-header">
        <div>
            <p class="page-kicker">Mon espace</p>
            <h1 class="page-title">Mon profil</h1>
        </div>
        <a href="{{ path('app_journey_new') }}" class="btn-accent">+ Nouveau carnet</a>
    </div>

    {% for message in app.flashes('success') %}
        <div class="flash flash-success">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="flash flash-error">{{ message }}</div>
    {% endfor %}

    {# Carte identité utilisateur #}
    <div class="form-card profile-card">
        <div class="profile-avatar">
            {{ app.user.username|first|upper }}
        </div>
        <div class="profile-info">
            <p class="profile-name">{{ app.user.username }}</p>
            <p class="profile-email">{{ app.user.email }}</p>
            <p class="profile-since">Membre depuis {{ app.user.createdAt|date('d/m/Y') }}</p>
        </div>
        <div class="profile-stats">
            <div>
                <p class="profile-stat-value profile-stat-value-accent">{{ published|length }}</p>
                <p class="profile-stat-label">Publiés</p>
            </div>
            <div>
                <p class="profile-stat-value profile-stat-value-medium">{{ drafts|length }}</p>
                <p class="profile-stat-label">Brouillons</p>
            </div>
            <div>
                <p class="profile-stat-value profile-stat-value-secondary">{{ published|length + drafts|length }}</p>
                <p class="profile-stat-label">Total</p>
            </div>
        </div>
    </div>

    {# Carnets publiés #}
    {% if published|length > 0 %}
    <div class="section-mb">
        <div class="section-header">
            <h2 class="section-title">Carnets publiés</h2>
            <span class="section-count">{{ published|length }} carnet{{ published|length > 1 ? 's' : '' }}</span>
        </div>
        <div class="list-grid">
            {% for journey in published %}
            <div class="list-card">
                <div class="list-card-image">
                    {% if journey.coverImage %}
                        <img src="{{ asset('uploads/journeys/' ~ journey.coverImage) }}" alt="{{ journey.title }}">
                    {% else %}
                        <div class="list-card-image-placeholder">🗺️</div>
                    {% endif %}
                    <span class="list-card-badge list-card-badge-secondary">Publié</span>
                </div>
                <div class="list-card-body">
                    <h3 class="list-card-title">{{ journey.title }}</h3>
                    <p class="list-card-text">{{ journey.description|slice(0, 90) }}...</p>
                    <div class="list-card-footer">
                        <span>{{ journey.duration }} jours · {{ journey.budget }} €</span>
                        <div class="list-card-actions">
                            <a href="{{ path('app_journey_show', {slug: journey.slug}) }}" class="list-card-link list-card-link-light">Voir</a>
                            <a href="{{ path('app_journey_edit', {slug: journey.slug}) }}" class="list-card-link list-card-link-accent">Modifier</a>
                        </div>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
    {% endif %}

    {# Brouillons #}
    {% if drafts|length > 0 %}
    <div class="section-mb-sm">
        <div class="section-header">
            <h2 class="section-title">Brouillons</h2>
            <span class="section-count">{{ drafts|length }} brouillon{{ drafts|length > 1 ? 's' : '' }}</span>
        </div>
        <div class="list-grid">
            {% for journey in drafts %}
            <div class="list-card list-card-draft">
                <div class="list-card-image">
                    {% if journey.coverImage %}
                        <img src="{{ asset('uploads/journeys/' ~ journey.coverImage) }}" alt="{{ journey.title }}">
                    {% else %}
                        <div class="list-card-image-placeholder">🗺️</div>
                    {% endif %}
                    <span class="list-card-badge journey-status-draft">Brouillon</span>
                </div>
                <div class="list-card-body">
                    <h3 class="list-card-title">{{ journey.title }}</h3>
                    <p class="list-card-text">{{ journey.description|slice(0, 90) }}...</p>
                    <div class="list-card-footer">
                        <span>{{ journey.duration }} jours · {{ journey.budget }} €</span>
                        <div class="list-card-actions">
                            <a href="{{ path('app_journey_show', {slug: journey.slug}) }}" class="list-card-link list-card-link-light">Voir</a>
                            <a href="{{ path('app_journey_edit', {slug: journey.slug}) }}" class="list-card-link list-card-link-accent">Modifier</a>
                        </div>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
    {% endif %}

    {# État vide #}
    {% if published|length == 0 and drafts|length == 0 %}
    <div class="empty-state">
        <p class="empty-state-title">Vous n'avez pas encore de carnet</p>
        <p class="empty-state-text">Commencez par raconter votre premier voyage !</p>
        <a href="{{ path('app_journey_new') }}" class="btn-accent">Créer mon premier carnet</a>
    </div>
    {% endif %}

    {# Zone suppression compte #}
    <div class="danger-zone">
        <p class="danger-zone-title">Supprimer mon compte</p>
        <p class="danger-zone-text">
            Cette action est définitive : votre compte, vos carnets, vos étapes et vos commentaires seront supprimés.
        </p>
        <form method="post"
              action="{{ path('app_profile_delete') }}"
              onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer votre compte ? Cette action est irréversible.');">
            <input type="hidden" name="_token" value="{{ csrf_token('delete-account' ~ app.user.id) }}">
            <button type="submit" class="btn-delete">
                Supprimer mon compte
            </button>
        </form>
    </div>

</div>
{% endblock %}
