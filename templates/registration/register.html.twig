{% extends 'base.html.twig' %}

{% block title %}S'inscrire — Horizons{% endblock %}

{% block body %}
<div class="page-container page-container-xs">

    <p class="page-kicker">Rejoindre la communauté</p>
    <h1 class="page-title">Créer un compte</h1>

    {{ form_errors(registrationForm) }}

    {{ form_start(registrationForm, {'attr': {'class': 'horizons-form', 'style': 'margin-top: 1.5rem;'}}) }}

        {{ form_row(registrationForm.username, {'label': 'Nom d\'utilisateur'}) }}
        {{ form_row(registrationForm.email, {'label': 'Email'}) }}
        {{ form_row(registrationForm.plainPassword, {'label': 'Mot de passe'}) }}
        <div class="form-check-row">
            {{ form_widget(registrationForm.agreeTerms) }}
            {{ form_label(registrationForm.agreeTerms, 'J\'accepte les conditions d\'utilisation') }}
            {{ form_errors(registrationForm.agreeTerms) }}
        </div>

        <button type="submit" class="btn-accent btn-full">
            Créer mon compte
        </button>

    {{ form_end(registrationForm) }}

    <p class="form-footer-link">
        Déjà un compte ?
        <a href="{{ path('app_login') }}">Se connecter</a>
    </p>

</div>
{% endblock %}
