{% extends 'base.html.twig' %}

{% block title %}Se connecter — Horizons{% endblock %}

{% block body %}
<div class="page-container" style="max-width: 450px;">

    <p class="page-kicker">Bon retour</p>
    <h1 class="page-title">Se connecter</h1>

    {% if error %}
        <div class="flash flash-error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
    {% endif %}

    <form method="post" class="horizons-form" style="margin-top: 1.5rem;">

        <div style="margin-bottom: 14px;">
            <label for="username">Email</label>
            <input type="email"
                   value="{{ last_username }}"
                   name="_username"
                   id="username"
                   autocomplete="email"
                   required
                   autofocus>
        </div>

        <div style="margin-bottom: 14px;">
            <label for="password">Mot de passe</label>
            <input type="password"
                   name="_password"
                   id="password"
                   autocomplete="current-password"
                   required>
        </div>

        {# Token CSRF  #}
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

        <button type="submit" class="btn-accent" style="width:100%;margin-top:8px;">
            Se connecter
        </button>

    </form>

    <p style="font-size:12px;color:var(--color-text-light);text-align:center;margin-top:16px;">
        Pas encore de compte ?
        <a href="{{ path('app_register') }}" style="color:var(--color-accent);">S'inscrire</a>
    </p>

</div>
{% endblock %}